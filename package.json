{
  "name": "mega-ml-suite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-sitemap.mjs && node scripts/audit-pages.mjs && node scripts/audit-navigation.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "audit:pages": "node scripts/audit-pages.mjs",
    "audit:navigation": "node scripts/audit-navigation.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "test:core": "node scripts/unit-core.cjs",
    "test:responsive": "playwright test tests/responsive.spec.ts --reporter=line"
  },
  "dependencies": {
    "@tensorflow-models/body-segmentation": "^1.0.2",
    "@tensorflow-models/hand-pose-detection": "^2.0.1",
    "@tensorflow-models/mobilenet": "^2.1.1",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "framer-motion": "^12.38.0",
    "idb": "^8.0.3",
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "simple-statistics": "^7.8.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
